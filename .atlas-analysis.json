  "keyFeatures": [
    "Vera One AI intelligence layer — signals, trends, and attribution across all connected platforms",
    "Multi-platform ad management — Meta Ads and Google Ads campaigns from one dashboard",
    "AI-powered skills — campaign analysis, SEO audits, content writing, lead scoring, and more",
    "Rule-based Action Engine — automate responses to signals (pause campaigns, tag contacts, send alerts)",
    "Lead scoring and pipeline management with GHL CRM integration",
    "AI Campaign Builder — build and launch Meta Ads campaigns with VERA guidance",
    "Client reporting — auto-generated weekly and monthly reports emailed to clients",
    "Landing page builder with multi-platform pixel injection and form-to-CRM lead capture",
    "VERA Chat — conversational AI for strategy, copy, and campaign planning",
    "ICP profiling and drift monitoring — track ideal customer profile vs observed audience"
  ],
